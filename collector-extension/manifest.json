{
  "manifest_version": 3,
  "name": "美客多国际购采集器",
  "version": "1.1.0",
  "description": "在本地已登录浏览器中低频采集四国国际购商品并上传到选品助手云端。",
  "permissions": ["storage", "tabs", "scripting", "alarms"],
  "host_permissions": [
    "https://*.mercadolibre.com.mx/*", "https://*.mercadolivre.com.br/*",
    "https://*.mercadolibre.cl/*", "https://*.mercadolibre.com.co/*",
    "https://mercado-cloud-admin-production.up.railway.app/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "国际购采集器" }
}
